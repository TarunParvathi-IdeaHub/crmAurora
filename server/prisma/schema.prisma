// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
 provider = "prisma-client-js"
 engineType = "binary"
}

datasource db {
 provider = "postgresql"
 url      = env("DATABASE_URL")
}

model Institution{
 id                 String    @id @default(uuid())
 institutionName    String
 institutionCode    String    @unique
 institutionArea    String
 institutionCity    String
 institutionPincode String?
 institutionState   String
 phoneNumber        String    @unique
 email              String    @unique
 isActive           Boolean   @default(true)

 employeeRoles        EmployeeRole[]
 schools              School[]
 departments          Department[]
 admins               Admin[]
 collegeAdmins        CollegeAdmin[]
 admissionDirectors   AdmissionDirector[]
 admissionIncharges   AdmissionIncharge[]
 admissionConsultants AdmissionConsultant[]
 admissionCounsellors AdmissionCounsellor[]
 degreeLevels         DegreeLevel[]
 programs             Program[]
 admissionCycles      AdmissionCycle[]
 enquiryForms         EnquiryForm[]
 studentAdmissionApplications StudentAdmissionApplication[]
 entranceExams EntranceExam[]
 documentVerifications DocumentVerification[]
 studentAdmissionUndertakingTemplates StudentAdmissionUndertakingTemplate[]
 studentAdmissionUndertakings StudentAdmissionUndertaking[]
 programChangeHistories ProgramChangeHistory[]
 institutionFinanceConfig InstitutionFinanceConfig[]
 feecategories FeeCategory[]
 paymentTransactions PaymentTransaction[]
 invoices Invoice[]
 receipts Receipt[]
 applicationFees ApplicationFee[]
 applicants Applicant[]
 academicYears AcademicYear[]
 batches Batch[]
 batchPrograms BatchProgram[]
 batchAcademicYears BatchAcademicYear[]
 batchAdmissionCycles BatchAdmissionCycle[]
 counsellorPerformances CounsellorPerformance[]
 consultantPerformances ConsultantPerformance[]

 createdAt         DateTime  @default(now())
 updatedAt         DateTime  @updatedAt

 @@map("institutions")
}

model User{
 id            String    @id @default(uuid())
 userId        String    @unique
 email         String    @unique
 password      String
 role          String
 isFirstLogin  Boolean   @default(true)
 isBlocked     Boolean   @default(false)

 createdAt     DateTime  @default(now())
 updatedAt     DateTime  @updatedAt

 @@map("users")
}

model EmployeeRole {
  id            String      @id @default(uuid())
  roleId        String      @unique
  role          String
  staffType     String
  rolePrefix    String      @unique
  roleCount     Int
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id])
  isActive      Boolean     @default(true)
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("employeeRoles")
}

model School{
  id            String      @id @default(uuid())
  schoolCode    String
  name          String
  phoneNumber   String      @unique
  email         String      @unique
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id])

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  isActive      Boolean     @default(true)

  @@unique([institutionId, schoolCode])

  departments   Department[]
  programs      Program[]

  @@map("schools")
}

model Department {
  id              String      @id @default(uuid())
  departmentCode  String
  name            String
  phoneNumber     String      @unique
  email           String      @unique
  institutionId   String
  institution     Institution @relation(fields: [institutionId], references: [id])
  schoolId        String?
  school          School?     @relation(fields: [schoolId], references: [id])

  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([institutionId, departmentCode])
  admins                Admin[]
  collegeAdmins         CollegeAdmin[]
  admissionDirectors    AdmissionDirector[]
  admissionIncharges    AdmissionIncharge[]
  admissionConsultants  AdmissionConsultant[]
  admissionCounsellors  AdmissionCounsellor[]
  programs              Program[]

  @@map("departments")
}

model DegreeLevel{
  id              String      @id @default(uuid())
  levelName       String
  institutionId   String
  institution     Institution @relation(fields: [institutionId], references:[id])

  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  programs        Program[]
  admissionCycles AdmissionCycle[]
  enquiryForms    EnquiryForm[]
  studentAdmissionApplications StudentAdmissionApplication[]
  applicants Applicant[]

  @@unique([institutionId, levelName])
  @@map("degreeLevels")
}

model AcademicYear {
  id String @id @default(uuid())

  institutionId String
  institution Institution @relation(fields: [institutionId], references: [id])

  academicYearName String   // 2026-27

  startDate DateTime
  endDate DateTime

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  batchAcademicYears BatchAcademicYear[]

  @@unique([institutionId, academicYearName])

  @@map("academicYears")
}

enum BatchStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

model Batch {
  id String @id @default(uuid())

  institutionId String
  institution Institution @relation(fields: [institutionId], references: [id])

  batchName String

  startDate DateTime
  endDate DateTime

  status BatchStatus @default(ACTIVE)

  description String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relations
  batchPrograms BatchProgram[]
  batchAcademicYears BatchAcademicYear[]
  batchAdmissionCycles BatchAdmissionCycle[]
  
  @@unique([institutionId, batchName])

  @@map("batches")
}

model BatchProgram {
  id String @id @default(uuid())

  institutionId String
  institution Institution @relation(fields: [institutionId], references: [id])

  batchId String
  batch Batch @relation(fields: [batchId], references: [id])

  programId String
  program Program @relation(fields: [programId], references: [id])

  intakeCapacity Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([batchId, programId])

  @@map("batchPrograms")
}

model BatchAcademicYear {
  id String @id @default(uuid())

  institutionId String
  institution Institution @relation(fields: [institutionId], references: [id])

  batchId String
  batch Batch @relation(fields: [batchId], references: [id])

  academicYearId String
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([batchId, academicYearId])

  @@map("batchAcademicYears")
}

model AdmissionCycle{
  id                 String      @id @default(uuid())
  admissionCycleName String
  institutionId      String
  institution        Institution @relation(fields: [institutionId], references: [id])
  levelId            String
  degreeLevel        DegreeLevel @relation(fields: [levelId], references: [id])
  programId          String
  program            Program     @relation(fields: [programId], references: [id])
  isActive           Boolean     @default(true)

  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  enquiryForms       EnquiryForm[]
  studentAdmissionApplications StudentAdmissionApplication[]
  batchAdmissionCycles BatchAdmissionCycle[]
  applicants Applicant[]
  @@unique([admissionCycleName, programId])
  @@map("admissionCycles")
}

model BatchAdmissionCycle {
  id String @id @default(uuid())

  institutionId String
  institution Institution @relation(fields: [institutionId], references: [id])

  batchId String
  batch Batch @relation(fields: [batchId], references: [id])

  admissionCycleId String
  admissionCycle AdmissionCycle @relation(fields: [admissionCycleId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([batchId, admissionCycleId])

  @@map("batchAdmissionCycles")
}

model Program{
  id              String       @id  @default(uuid())
  programCode     String
  programName     String
  programSname    String
  institutionId   String
  institution     Institution  @relation(fields: [institutionId], references:[id])
  levelId         String
  level           DegreeLevel  @relation(fields: [levelId], references:[id])
  schoolId        String?
  school          School?       @relation(fields: [schoolId], references:[id])
  departmentId     String?
  department       Department?    @relation(fields: [departmentId], references:[id])  
  
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([institutionId, programCode])

  admissionCycles AdmissionCycle[]
  enquiryForms    EnquiryForm[]
  studentAdmissionApplications StudentAdmissionApplication[]
  studentAdmissionUndertakingTemplates StudentAdmissionUndertakingTemplate[]
  studentAdmissionUndertakings StudentAdmissionUndertaking[]
  actualProgramChangeHistories ProgramChangeHistory[] @relation("actualProgramChange")
  newProgramChangeHistories ProgramChangeHistory[] @relation("NewProgramChange")
  batchPrograms BatchProgram[]
  applicants Applicant[]
  @@map("programs")
}

model Admin{
  id                String      @id @default(uuid())
  institutionId     String
  institution       Institution @relation(fields: [institutionId], references:[id])
  empId             String      @unique
  departmentId      String?
  department        Department? @relation(fields: [departmentId], references:[id])
  firstName         String
  lastName          String
  designation       String
  staffType         String
  email             String      @unique
  mobileNo          String      @unique
  alternateMobileNo String
  emergencyContact  String
  address           String
  bloodGroup        String
  caste             String
  sscMemo           String?
  intermediateMemo  String?
  ugMemo            String?
  pgMemo            String?
  phdMemo           String?
  isActive          Boolean     @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}


model CollegeAdmin{
  id                String      @id @default(uuid())
  institutionId     String
  institution       Institution @relation(fields: [institutionId], references:[id])
  departmentId      String?
  department        Department? @relation(fields: [departmentId], references:[id])
  empId             String      @unique
  firstName         String
  lastName          String
  designation       String
  staffType         String
  email             String      @unique
  mobileNo          String      @unique
  alternateMobileNo String
  emergencyContact  String
  address           String
  bloodGroup        String
  caste             String
  sscMemo           String?
  intermediateMemo  String?
  ugMemo            String?
  pgMemo            String?
  phdMemo           String?
  isActive          Boolean     @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("collegeAdmins")
}

model AdmissionDirector{
  id                String      @id @default(uuid())
  institutionId     String
  institution       Institution @relation(fields: [institutionId], references:[id])
  departmentId      String?
  department        Department? @relation(fields: [departmentId], references:[id])
  empId             String      @unique
  firstName         String
  lastName          String
  designation       String
  staffType         String
  email             String      @unique
  mobileNo          String      @unique
  alternateMobileNo String
  emergencyContact  String
  address           String
  bloodGroup        String
  caste             String
  sscMemo           String?
  intermediateMemo  String?
  ugMemo            String?
  pgMemo            String?
  phdMemo           String?
  isActive          Boolean     @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admissionDirectors")
}

model AdmissionIncharge{
  id                String      @id @default(uuid())
  institutionId     String
  institution       Institution @relation(fields: [institutionId], references:[id])
  departmentId      String?
  department        Department? @relation(fields: [departmentId], references:[id])
  empId             String      @unique
  firstName         String
  lastName          String
  designation       String
  staffType         String
  email             String      @unique
  mobileNo          String      @unique
  alternateMobileNo String
  emergencyContact  String
  address           String
  bloodGroup        String
  caste             String
  sscMemo           String?
  intermediateMemo  String?
  ugMemo            String?
  pgMemo            String?
  phdMemo           String?
  isActive          Boolean     @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admissionIncharges")
}

model AdmissionConsultant{
  id                String      @id @default(uuid())
  institutionId     String
  institution       Institution @relation(fields: [institutionId], references:[id])
  departmentId      String?
  department        Department? @relation(fields: [departmentId], references:[id])
  empId             String      @unique
  firstName         String
  lastName          String
  designation       String
  staffType         String
  email             String      @unique
  mobileNo          String      @unique
  alternateMobileNo String
  emergencyContact  String
  address           String
  bloodGroup        String
  caste             String
  sscMemo           String?
  intermediateMemo  String?
  ugMemo            String?
  pgMemo            String?
  phdMemo           String?
  isActive          Boolean     @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  enquiryForms  EnquiryForm[]
  consultantPerformances ConsultantPerformance[]
  consultantCallLogs  ConsultantCallLog[]
  studentAdmissionApplications StudentAdmissionApplication[]

  @@map("admissionConsultants")
}

model AdmissionCounsellor{
  id                String      @id @default(uuid())
  institutionId     String
  institution       Institution @relation(fields: [institutionId], references:[id])
  departmentId      String?
  department        Department? @relation(fields: [departmentId], references:[id])
  empId             String      @unique
  firstName         String
  lastName          String
  designation       String
  staffType         String
  email             String      @unique
  mobileNo          String      @unique
  alternateMobileNo String
  emergencyContact  String
  address           String
  bloodGroup        String
  caste             String
  sscMemo           String?
  intermediateMemo  String?
  ugMemo            String?
  pgMemo            String?
  phdMemo           String?
  isActive          Boolean     @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  enquiryForms  EnquiryForm[]
  counsellorPerformances CounsellorPerformance[]
  counsellorCallLogs  CounsellorCallLog[]
  studentAdmissionApplications StudentAdmissionApplication[]
  @@map("admissionCounsellors")
}

model EnquiryForm{
  id                    String          @id @default(uuid())
  firstName             String
  lastName              String
  mobileNo              String
  email                 String          @unique
  state                 String
  consentForContact     Boolean         @default(true)
  institutionId         String
  institution           Institution         @relation(fields: [institutionId], references: [id])
  levelId               String
  degreeLevel           DegreeLevel         @relation(fields: [levelId], references: [id])
  programId             String
  program               Program             @relation(fields: [programId], references: [id])
  admissionCycleId      String
  admissionCycle        AdmissionCycle      @relation(fields: [admissionCycleId], references: [id])
  leadSourceType        LeadSourceType
  admissionCounsellorId String?
  admissionCounsellors   AdmissionCounsellor? @relation(fields: [admissionCounsellorId], references: [id])
  admissionConsultantId String?
  admissionConsultants  AdmissionConsultant? @relation(fields:[admissionConsultantId], references: [id])
  result                AdmissionResult?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  counsellorCallLogs  CounsellorCallLog[]
  consultantCallLogs  ConsultantCallLog[]
  studentAdmissionApplications StudentAdmissionApplication[]
  applicants Applicant[]


  @@map("enquiryForms")

}

enum LeadSourceType {
  SYSTEM_ASSIGNED
  OWN_GENERATED
}


enum AdmissionResult {
  ADMITTED
  NOT_ADMITTED
}

model CounsellorPerformance {
  id String @id @default(uuid())

  institutionId String
  institution Institution @relation(fields: [institutionId], references: [id])

  counsellorId String
  counsellor AdmissionCounsellor @relation(fields: [counsellorId], references: [id])

  // tracking period
  month Int
  year Int

  // SYSTEM GENERATED LEADS
  systemAssignedLeads Int @default(0)
  systemClosedLeads Int @default(0)
  systemAdmittedStudents Int @default(0)
  systemNotAdmittedStudents Int @default(0)

  // OWN LEADS
  ownGeneratedLeads Int @default(0)
  ownClosedLeads Int @default(0)
  ownAdmittedStudents Int @default(0)
  ownNotAdmittedStudents Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([counsellorId, month, year])

  @@map("counsellorPerformances")
}

model ConsultantPerformance {
  id String @id @default(uuid())

  institutionId String
  institution Institution @relation(fields: [institutionId], references: [id])

  consultantId String
  consultant AdmissionConsultant @relation(fields: [consultantId], references: [id])

  // tracking period

  month Int
  year Int

  // SYSTEM GENERATED LEADS
  systemAssignedLeads Int @default(0)
  systemClosedLeads Int @default(0)
  systemAdmittedStudents Int @default(0)
  systemNotAdmittedStudents Int @default(0)

  // OWN LEADS
  ownGeneratedLeads Int @default(0)
  ownClosedLeads Int @default(0)
  ownAdmittedStudents Int @default(0)
  ownNotAdmittedStudents Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([consultantId, month, year])

  @@map("consultantPerformances")
}


model CounsellorCallLog{
  id  String  @id @default(uuid())
  enquiryId String
  enquiry EnquiryForm @relation(fields: [enquiryId], references: [id])
  counsellorId  String
  counsellor   AdmissionCounsellor  @relation(fields:[counsellorId], references:[id])
  callType  CallType
  callStatus  CallStatus
  callResponse  String
  notes String?
  callTime  DateTime
  nextFollowUp  DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("counsellorCallLogs")
}

model ConsultantCallLog{
  id  String  @id @default(uuid())
  enquiryId String
  enquiry EnquiryForm @relation(fields: [enquiryId], references: [id])
  consultantId  String
  consultant   AdmissionConsultant  @relation(fields:[consultantId], references:[id])
  callType  CallType
  callStatus  CallStatus
  callResponse  String
  notes String?
  callTime  DateTime
  nextFollowUp  DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("consultantCallLogs")
}


enum CallType {
  INBOUND
  OUTBOUND
}

enum CallStatus {
  ANSWERED
  NO_RESPONSE
  BUSY
  REJECTED
}

model Applicant {
  id                            String              @id @default(uuid())
  firstName                     String
  lastName                      String
  mobileNo                      String
  email                         String              @unique
  role                          String?             @default("Applicant")
  userId                        String?             @unique
  institutionId                 String
  institution                   Institution         @relation(fields: [institutionId], references: [id])
  levelId                       String
  degreeLevel                   DegreeLevel         @relation(fields: [levelId], references: [id])
  programId                     String
  program                       Program             @relation(fields: [programId], references: [id])
  admissionCycleId              String
  admissionCycle                AdmissionCycle      @relation(fields: [admissionCycleId], references: [id])
  enquiryId                     String
  enquiry                       EnquiryForm         @relation(fields: [enquiryId], references: [id])
  studentAdmissionApplicationId String?
  studentAdmissionApplication   StudentAdmissionApplication? @relation(fields: [studentAdmissionApplicationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("applicants")
}

model StudentAdmissionApplication{
  id String @id @default(uuid())
  institutionId String
  institution Institution @relation(fields: [institutionId], references: [id])
  degreeLevelId String
  degreeLevel DegreeLevel @relation(fields: [degreeLevelId], references: [id])
  programId String
  program Program @relation(fields: [programId], references: [id])
  admissionCycleId String
  admissionCycle AdmissionCycle @relation(fields: [admissionCycleId], references: [id])
  admissionCounsellorId String?
  admissionCounsellor AdmissionCounsellor? @relation(fields: [admissionCounsellorId], references: [id])
  admissionConsultantId String?
  admissionConsultant AdmissionConsultant? @relation(fields: [admissionConsultantId], references: [id])
  enquiryId String?
  enquiry EnquiryForm? @relation(fields: [enquiryId], references: [id])
  applicationNumber String? @unique
  //Basic Details
  firstName String
  lastName String
  email String
  mobileNo String
  gender String?
  fatherName String?
  fatherMobileNo String?
  fatherEmail String?
  motherName String?
  motherMobileNo String?
  motherEmail String?
  dateOfBirth DateTime?
  aadharNo String?
  bloodGroup String?
  caste String?
  subCaste String?
  state String?
  city String?
  pincode String?
  presentAddress String?
  permanentAddress String?
  //Entrance Exam Details
  quallingEntranceExam String?
  entranceExamHallTicketNo String?
  entranceExamRank String?
  intrestedInAurumExam  Boolean @default(true)
  aurumExamTime DateTime?
  //Documents
  aadharCard String?
  sscMemo String?
  intermediateMemo String?
  ugMemo String?
  pgMemo String?
  gapCertificate String?
  bonafideCertificate String?
  transferCertificate String?
  isActive          Boolean     @default(true)

  applicationStatus ApplicationStatus @default(SAVED_AS_DRAFT)

  consentDeclaration String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  studentEducationDetails StudentEducationDetails[]
  invoices Invoice[]
  entranceExams EntranceExam[]
  documentVerifications DocumentVerification[]
  studentAdmissionUndertakings StudentAdmissionUndertaking[]
  programChangeHistories ProgramChangeHistory[]
  paymentTransactions PaymentTransaction[]
  receipts Receipt[]
  applicationFees ApplicationFee[]
  applicants Applicant[]
  @@map("studentAdmissionApplications")
}

enum ApplicationStatus {
  SAVED_AS_DRAFT
  APPLICATION_FEE_DUE
  APPLICATION_FEE_PAID
  APPLICATION_SUBMITTED
  AURUM_EXAM_PENDING
  AURUM_EXAM_PASSED
  AURUM_EXAM_FAILED
  DOCUMENT_VERIFICATION_PENDING
  DOCUMENT_VERIFIED
  DOCUMENT_VERIFICATION_FAILED
  REGISTRATION_FEE_DUE
  TUITION_FEE_DUE
  STUDENT_ADMISSION_UNDERTAKING_PENDING
  STUDENT_ADMISSION_UNDERTAKING_SUBMITTED
  ADMISSION_GRANTED
  ADMISSION_REJECTED
}

model StudentEducationDetails{
  id String @id @default(uuid())
  studentAdmissionApplicationId String?
  studentAdmissionApplication StudentAdmissionApplication? @relation(fields: [studentAdmissionApplicationId], references: [id])
  studentName String
  uid String?
  applicationNumber String?
  sscBoard String?
  sscYearOfPassing Int?
  sscHallTicketNo String?
  sscInstitutionName String?
  sscPercentage Float?
  intermediateBoard String?
  intermediateYearOfPassing Int?
  intermediateHallTicketNo String?
  intermediateInstitutionName String?
  intermediatePercentage Float?
  ugBoard String?
  ugYearOfPassing Int?
  ugHallTicketNo String?
  ugInstitutionName String?
  ugPercentage Float?
  pgBoard String?
  pgInstitutionName String?
  pgHallTicketNo String?
  pgYearOfPassing Int?
  pgPercentage Float?

  @@map("studentEducationDetails")
}

enum ExamType {
  EXTERNAL
  AURUM
}

enum ExamStatus {
  PENDING
  PASSED
  FAILED
}

model EntranceExam{
  id String @id @default(uuid())

  institutionId String
  institution Institution @relation(fields: [institutionId], references: [id])

  studentAdmissionApplicationId String
  studentAdmissionApplication StudentAdmissionApplication @relation(fields: [studentAdmissionApplicationId], references: [id])
  examType ExamType
  
  examName String?
  hallTicketNo String?
  rank String?

  examLink String?
  assignedAt DateTime?
  completedAt DateTime?
  score Int?
  status ExamStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentAdmissionApplicationId])

  @@map("entranceExams")
}

enum VerificationFinalStatus {
  DOCUMENTS_VERIFICATION_PENDING
  DOCUMENTS_VERIFIED
  DOCUMENTS_REJECTED
}

enum VerificationStatus {
  DOCUMENT_VERIFICATION_PENDING
  DOCUMENT_VERIFIED
  DOCUMENT_REJECTED
}


model DocumentVerification {
  id String @id @default(uuid())
  studentAdmissionApplicationId String @unique
  studentAdmissionApplication StudentAdmissionApplication @relation(fields: [studentAdmissionApplicationId], references: [id])
  
  institutionId String
  institution Institution @relation(fields: [institutionId], references: [id])

  // verifier
  verifiedById String
  verifiedByRole String

  // final result
  status VerificationFinalStatus @default(DOCUMENTS_VERIFICATION_PENDING)

  remarks String?

  verifiedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  verificationItems VerificationItem[]

  @@map("documentVerifications")
}

enum VerificationDocumentType {
  AADHAR_CARD
  SSC_MEMO
  INTERMEDIATE_MEMO
  UG_MEMO
  PG_MEMO
  GAP_CERTIFICATE
  BONAFIDE_CERTIFICATE
  TRANSFER_CERTIFICATE
  ENTRANCE_EXAM
}

model VerificationItem {
  id String @id @default(uuid())

  verificationId String
  verification DocumentVerification @relation(fields: [verificationId], references: [id])

  documentType VerificationDocumentType

  status VerificationStatus @default(DOCUMENT_VERIFICATION_PENDING)

  remarks String?

  verifiedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([verificationId, documentType])

  @@map("verificationItems")
}

model StudentAdmissionUndertakingTemplate {
  id String @id @default(uuid())

  institutionId String
  institution Institution @relation(fields: [institutionId], references: [id])

  programId String
  program Program @relation(fields: [programId], references: [id])

  title String
  version String
  description String?

  content Json

  isActive Boolean @default(true)
  publishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  studentAdmissionUndertakings StudentAdmissionUndertaking[]

  @@map("studentAdmissionUndertakingTemplates")
}

enum UndertakingStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model StudentAdmissionUndertaking {
  id String @id @default(uuid())

  institutionId String
  institution Institution @relation(fields: [institutionId], references: [id])

  studentAdmissionApplicationId String @unique
  studentAdmissionApplication StudentAdmissionApplication @relation(fields: [studentAdmissionApplicationId], references: [id])

  applicationNumber String  
  nameOfTheStudent String
  programId String
  program Program @relation(fields: [programId], references: [id])
  programEnrolling String

  studentDelaration String

  templateId String
  template StudentAdmissionUndertakingTemplate  @relation(fields: [templateId], references: [id])

  status UndertakingStatus @default(PENDING)

  // snapshot of accepted content
  acceptedContent Json

  // dynamic fee values
  tuitionFee Float?
  admissionFee Float?
  specialFee Float?
  placementTrainingFee Float?

  studentAccepted Boolean @default(false)

  studentAcceptedAt DateTime?

  ipAddress String?
  userAgent String?

  isLocked Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("studentAdmissionUndertakings")
}

model ProgramChangeHistory {
  id String @id @default(uuid())

  institutionId String
  institution Institution @relation(fields: [institutionId], references: [id])

  studentAdmissionApplicationId String @unique
  studentAdmissionApplication StudentAdmissionApplication @relation(fields: [studentAdmissionApplicationId], references: [id])

  actualProgramId String
  actualProgram Program @relation("actualProgramChange", fields: [actualProgramId], references: [id])

  newProgramId String
  newProgram Program @relation("NewProgramChange", fields: [newProgramId], references: [id])

  reason String?

  changedById String
  changedByRole String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("programChangeHistories")
}

model InstitutionFinanceConfig {
  id String @id @default(uuid())

  institutionId String @unique
  institution Institution @relation(fields: [institutionId], references: [id])

  invoicePrefix String   // AUU
  receiptPrefix String   // AUUR

  currentInvoiceNumber Int @default(0)
  currentReceiptNumber Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("institutionFinanceConfigs")
}

enum InvoiceStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

model Invoice {
  id String @id @default(uuid())

  institutionId String
  institution Institution @relation(fields: [institutionId], references: [id])

  invoiceNumber String @unique

  invoiceDate DateTime
  dueDate DateTime?

  studentAdmissionApplicationId String?
  studentAdmissionApplication StudentAdmissionApplication? @relation(fields: [studentAdmissionApplicationId], references: [id])

  feeCategoryId String
  feeCategory FeeCategory @relation(fields: [feeCategoryId], references: [id])

  amount Float

  status InvoiceStatus @default(PENDING)

  remarks String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  paymentTransactions PaymentTransaction[]
  applicationFees ApplicationFee[]
  @@map("invoices")
}

enum PaymentType {
  ONLINE
  CASH
  CHEQUE
  BANK_TRANSFER
  UPI
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

model PaymentTransaction {
  id String @id @default(uuid())

  institutionId String
  institution Institution @relation(fields: [institutionId], references: [id])

  invoiceId String
  invoice Invoice @relation(fields: [invoiceId], references: [id])

  studentAdmissionApplicationId String?
  studentAdmissionApplication StudentAdmissionApplication? @relation(fields: [studentAdmissionApplicationId], references: [id])

  transactionId String? @unique

  amount Float
  amountPaid Float
  amountDue Float
  

  paymentType PaymentType

  collectionDate DateTime?

  gatewayName String?

  paymentStatus PaymentStatus @default(PENDING)

  easebuzzPaymentId String?
  orderId String?

  remarks String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  receipt Receipt?

  @@map("paymentTransactions")
}

model Receipt {
  id String @id @default(uuid())

  institutionId String
  institution Institution @relation(fields: [institutionId], references: [id])

  paymentTransactionId String @unique
  paymentTransaction PaymentTransaction @relation(fields: [paymentTransactionId], references: [id])

  studentAdmissionApplicationId String?
  studentAdmissionApplication StudentAdmissionApplication? @relation(fields: [studentAdmissionApplicationId], references: [id])

  receiptNumber String @unique

  receiptDate DateTime

  amount Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("receipts")
}

enum FeeCategoryType {
  APPLICATION_FEE
  REGISTRATION_FEE
  TUITION_FEE
  HOSTEL_FEE
  TRANSPORT_FEE
  EXAM_FEE
}

model FeeCategory {
  id String @id @default(uuid())

  institutionId String
  institution Institution @relation(fields: [institutionId], references: [id])

  categoryType FeeCategoryType

  feeName String
  amount Float?

  isFixed Boolean @default(true)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([institutionId, categoryType])
  invoices Invoice[]
  applicationFees ApplicationFee[]

  @@map("feeCategories")
}

model ApplicationFee {
  id String @id @default(uuid())

  institutionId String
  institution Institution @relation(fields: [institutionId], references: [id])

  studentAdmissionApplicationId String @unique
  studentAdmissionApplication StudentAdmissionApplication @relation(fields: [studentAdmissionApplicationId], references: [id])

  invoiceId String @unique
  invoice Invoice @relation(fields: [invoiceId], references: [id])

  feeCategoryId String
  feeCategory FeeCategory @relation(fields: [feeCategoryId], references: [id])

  amount Float @default(1)
  amountPaid Float @default(0)
  amountDue Float @default(1)

  paymentStatus PaymentStatus @default(PENDING)

  paidAt DateTime?

  remarks String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("applicationFees")
}